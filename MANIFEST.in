# Include recipe and platform files (now inside ece4_exp package)
recursive-include ece4_exp/recipes *.yml *.yaml
recursive-include ece4_exp/platforms *.yml *.yaml

# Include documentation
include README.md
include LICENSE

# Exclude development files
exclude ece4-exp
exclude setup.sh
recursive-exclude autosubmit *
global-exclude *.pyc __pycache__
